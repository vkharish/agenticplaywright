{
  "name": "zephyr-playwright-automation",
  "version": "1.0.0",
  "description": "Agentic Playwright test automation framework for Jira Zephyr test cases",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report playwright-report",
    "test:zephyr": "playwright test tests/zephyr/ --project=public-chromium",
    "test:zephyr:headed": "playwright test tests/zephyr/ --project=public-chromium --headed",
    "codegen": "playwright codegen",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.7.0"
  }
}
