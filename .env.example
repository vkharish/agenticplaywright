# ─── Target Environment ─────────────────────────────────────────────────────
BASE_URL=https://staging.myapp.com

# ─── Default test account (used by specs that don't specify an app prefix) ───
TEST_USERNAME=your_username_here
TEST_PASSWORD=your_password_here

# ─── Per-app credentials ─────────────────────────────────────────────────────
# Pattern: <APP_PREFIX>_USERNAME / <APP_PREFIX>_PASSWORD
# The prefix comes from the `credentials:` field in your test-cases .md file.
#
# Example app: The Internet (herokuapp)
THE_INTERNET_USERNAME=tomsmith
THE_INTERNET_PASSWORD=SuperSecretPassword!
#
# Add one block per application you test:
# MY_APP_USERNAME=qa_user@mycompany.com
# MY_APP_PASSWORD=the_test_password
#
# NEVER commit a real .env file — .env is in .gitignore

# ─── Zephyr / Jira Integration ───────────────────────────────────────────────
ZEPHYR_API_TOKEN=
JIRA_PROJECT_KEY=QA
JIRA_BASE_URL=https://yourorg.atlassian.net

# ─── CI / Parallelism ────────────────────────────────────────────────────────
CI=false
