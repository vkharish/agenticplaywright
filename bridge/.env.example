# ── Bridge ────────────────────────────────────────────────────────────────────
# API key that n8n / curl sends in the x-api-key header.
# Leave unset to skip auth (dev mode only).
BRIDGE_API_KEY=change-me-in-production

# Port the Express server listens on (default 3000)
PORT=3000

# ── Claude API ────────────────────────────────────────────────────────────────
# Required for POST /generate-spec.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── n8n (Docker only) ────────────────────────────────────────────────────────
# Must be exactly 32 characters.
N8N_ENCRYPTION_KEY=changeme-32-char-encryption-key!

# Personal API key — create in n8n UI: Settings → n8n API → Create key
N8N_API_KEY=
